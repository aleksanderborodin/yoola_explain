{
  "manifest_version": 3,
  "name": "Yoola — ToS Summarizer",
  "version": "0.2.0",
  "description": "Detects terms-of-service pages and shows a grounded, checklist-based summary. Alarming clauses first, every claim traceable to the source text.",
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": { "16": "images/icon16.png", "48": "images/icon48.png" }
  },
  "permissions": ["storage", "activeTab", "contextMenus", "alarms", "scripting"],
  "host_permissions": ["http://127.0.0.1:8000/*", "https://yoola-explain.aleksanderbor.ru/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["detect.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
